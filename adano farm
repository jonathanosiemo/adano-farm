<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AI Drought Monitoring Dashboard</title>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

  <style>
    :root{
      --bg1: rgba(8, 12, 16, 0.70);
      --bg2: rgba(18, 24, 31, 0.55);
      --card: rgba(255,255,255,0.10);
      --card-border: rgba(255,255,255,0.18);
      --text: #f4f7fb;
      --muted: #c9d3dd;
      --gold: #f5c451;
      --green: #24d27d;
      --yellow: #ffd54f;
      --orange: #ff9d2e;
      --red: #ff5757;
      --cyan: #4fd1ff;
      --blue: #5a8dff;
      --shadow: 0 10px 30px rgba(0,0,0,0.25);
      --radius: 20px;
    }

    *{
      box-sizing: border-box;
      margin: 0;
      padding: 0;
      font-family: "Segoe UI", Arial, sans-serif;
    }

    html, body{
      width: 100%;
      height: 100%;
      overflow: hidden; /* single page no scroll */
      color: var(--text);
      background:
        linear-gradient(135deg, rgba(0,0,0,0.65), rgba(0,0,0,0.55)),
        url('https://images.unsplash.com/photo-1500382017468-9049fed747ef?auto=format&fit=crop&w=1800&q=80') center/cover no-repeat fixed;
    }

    body{
      padding: 10px;
    }

    .dashboard{
      width: 100%;
      height: calc(100vh - 20px);
      display: grid;
      grid-template-columns: 1.15fr 1.1fr 0.95fr;
      grid-template-rows: 88px 1fr 1fr;
      gap: 10px;
    }

    .glass{
      background: linear-gradient(145deg, var(--card), rgba(255,255,255,0.05));
      border: 1px solid var(--card-border);
      box-shadow: var(--shadow);
      border-radius: var(--radius);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      overflow: hidden;
    }

    /* HEADER */
    .header{
      grid-column: 1 / 4;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 14px 20px;
      background: linear-gradient(135deg, rgba(0,0,0,0.35), rgba(255,255,255,0.08));
    }

    .header-left h1{
      font-size: 1.55rem;
      color: var(--gold);
      letter-spacing: 0.3px;
      margin-bottom: 5px;
    }

    .header-left p{
      font-size: 0.95rem;
      color: var(--muted);
    }

    .header-right{
      display: flex;
      gap: 12px;
      align-items: center;
    }

    .pill{
      min-width: 150px;
      padding: 12px 16px;
      border-radius: 16px;
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.12);
      text-align: center;
    }

    .pill .label{
      font-size: 0.75rem;
      color: var(--muted);
      margin-bottom: 4px;
      text-transform: uppercase;
      letter-spacing: 0.7px;
    }

    .pill .value{
      font-size: 1.05rem;
      font-weight: 700;
    }

    .online{
      color: var(--green);
    }

    /* LEFT COLUMN */
    .left-col{
      display: grid;
      grid-template-rows: 1fr 1fr;
      gap: 10px;
    }

    .hero-panel{
      padding: 16px;
      display: grid;
      grid-template-columns: 1.05fr 0.95fr;
      gap: 14px;
      min-height: 0;
    }

    .risk-box{
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      padding: 10px;
      min-height: 0;
    }

    .section-title{
      font-size: 0.88rem;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.8px;
      margin-bottom: 10px;
    }

    .big-risk{
      display: flex;
      align-items: center;
      justify-content: center;
      flex: 1;
      min-height: 0;
      position: relative;
    }

    .ring{
      --percent: 72;
      --color: var(--orange);
      width: min(18vw, 220px);
      height: min(18vw, 220px);
      border-radius: 50%;
      background:
        radial-gradient(closest-side, rgba(10,16,22,0.92) 72%, transparent 73% 100%),
        conic-gradient(var(--color) calc(var(--percent) * 1%), rgba(255,255,255,0.12) 0);
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      box-shadow: inset 0 0 30px rgba(0,0,0,0.25);
    }

    .ring::before{
      content: "";
      position: absolute;
      inset: 12px;
      border-radius: 50%;
      border: 1px solid rgba(255,255,255,0.08);
    }

    .ring-content{
      text-align: center;
      z-index: 2;
    }

    .ring-content h2{
      font-size: 2.2rem;
      line-height: 1;
      margin-bottom: 6px;
    }

    .ring-content span{
      display: block;
      font-size: 0.9rem;
      color: var(--muted);
    }

    .risk-footer{
      margin-top: 10px;
      display: flex;
      gap: 10px;
    }

    .mini-stat{
      flex: 1;
      padding: 12px;
      border-radius: 16px;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.08);
    }

    .mini-stat .small-label{
      font-size: 0.78rem;
      color: var(--muted);
      margin-bottom: 6px;
    }

    .mini-stat .small-value{
      font-size: 1.2rem;
      font-weight: 700;
    }

    .status-panel{
      padding: 10px;
      display: grid;
      grid-template-rows: auto 1fr auto;
      min-height: 0;
    }

    .status-badges{
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
      margin-bottom: 10px;
    }

    .badge{
      padding: 12px;
      border-radius: 16px;
      background: rgba(255,255,255,0.07);
      border: 1px solid rgba(255,255,255,0.10);
    }

    .badge .name{
      font-size: 0.78rem;
      color: var(--muted);
      margin-bottom: 6px;
    }

    .badge .num{
      font-size: 1.3rem;
      font-weight: 700;
    }

    .recommendation{
      margin-top: 8px;
      padding: 12px 14px;
      border-radius: 16px;
      background: rgba(36, 210, 125, 0.10);
      border-left: 5px solid var(--green);
      font-size: 0.92rem;
      line-height: 1.5;
      color: #edf7f1;
    }

    .alert{
      margin-top: 10px;
      padding: 12px 14px;
      border-radius: 16px;
      background: rgba(255, 87, 87, 0.10);
      border-left: 5px solid var(--red);
      font-size: 0.92rem;
      line-height: 1.45;
    }

    /* CENTER COLUMN */
    .center-col{
      display: grid;
      grid-template-rows: 1.05fr 0.95fr;
      gap: 10px;
      min-height: 0;
    }

    .gauges-panel{
      padding: 14px;
      display: grid;
      grid-template-rows: auto 1fr;
      min-height: 0;
    }

    .gauge-grid{
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: repeat(2, 1fr);
      gap: 12px;
      min-height: 0;
    }

    .gauge-card{
      padding: 12px;
      border-radius: 18px;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.10);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 0;
    }

    .gauge-title{
      font-size: 0.82rem;
      color: var(--muted);
      margin-bottom: 8px;
      text-transform: uppercase;
      letter-spacing: 0.7px;
    }

    .small-ring{
      --percent: 50;
      --color: var(--cyan);
      width: min(8.8vw, 120px);
      height: min(8.8vw, 120px);
      border-radius: 50%;
      background:
        radial-gradient(closest-side, rgba(8,13,18,0.95) 72%, transparent 73% 100%),
        conic-gradient(var(--color) calc(var(--percent) * 1%), rgba(255,255,255,0.12) 0);
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
    }

    .small-ring span{
      font-size: 1.15rem;
      font-weight: 700;
    }

    .gauge-sub{
      margin-top: 8px;
      font-size: 0.78rem;
      color: var(--muted);
      text-align: center;
    }

    .bars-panel{
      padding: 14px;
      display: grid;
      grid-template-rows: auto 1fr;
      min-height: 0;
    }

    .bar-wrap{
      display: grid;
      gap: 12px;
      align-content: center;
    }

    .progress-item{
      background: rgba(255,255,255,0.05);
      border-radius: 16px;
      padding: 10px 12px;
      border: 1px solid rgba(255,255,255,0.08);
    }

    .progress-top{
      display: flex;
      justify-content: space-between;
      font-size: 0.9rem;
      margin-bottom: 8px;
    }

    .progress-top span:first-child{
      color: var(--muted);
    }

    .bar{
      height: 12px;
      border-radius: 999px;
      background: rgba(255,255,255,0.10);
      overflow: hidden;
      position: relative;
    }

    .fill{
      height: 100%;
      border-radius: 999px;
      position: relative;
      overflow: hidden;
      animation: grow 1.6s ease forwards;
    }

    .fill::after{
      content: "";
      position: absolute;
      top: 0;
      left: -60%;
      width: 50%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.5), transparent);
      animation: shimmer 2.2s infinite linear;
    }

    .soil-fill{ background: linear-gradient(90deg, #7be495, #22c55e); width: 28%; }
    .temp-fill{ background: linear-gradient(90deg, #ffd54f, #ff9800); width: 76%; }
    .hum-fill{ background: linear-gradient(90deg, #67e8f9, #3b82f6); width: 42%; }
    .rain-fill{ background: linear-gradient(90deg, #c084fc, #8b5cf6); width: 10%; }

    @keyframes shimmer{
      from{ left: -60%; }
      to{ left: 120%; }
    }

    @keyframes grow{
      from{ transform: scaleX(0.1); transform-origin: left; opacity: 0.7; }
      to{ transform: scaleX(1); transform-origin: left; opacity: 1; }
    }

    /* RIGHT COLUMN */
    .right-col{
      display: grid;
      grid-template-rows: 1fr 1fr;
      gap: 10px;
      min-height: 0;
    }

    .chart-panel, .trend-panel{
      padding: 12px 14px 8px;
      display: grid;
      grid-template-rows: auto 1fr;
      min-height: 0;
    }

    .chart-box{
      position: relative;
      min-height: 0;
      height: 100%;
    }

    canvas{
      width: 100% !important;
      height: 100% !important;
    }

    .legend-note{
      font-size: 0.78rem;
      color: var(--muted);
      margin-top: 6px;
      text-align: right;
    }

    /* RESPONSIVE */
    @media (max-width: 1200px){
      body{ overflow: auto; }
      html, body{ overflow: auto; }
      .dashboard{
        height: auto;
        grid-template-columns: 1fr;
        grid-template-rows: auto;
      }
      .header{ grid-column: auto; }
      .left-col, .center-col, .right-col{
        min-height: 500px;
      }
    }
  </style>
</head>
<body>
  <div class="dashboard">

    <!-- HEADER -->
    <div class="header glass">
      <div class="header-left">
        <h1>AI-Based Environmental Monitoring & Drought Risk Prediction System</h1>
        <p>Senior Chief Adano Day Girls • Wajir County • Smart Agriculture Dashboard</p>
      </div>

      <div class="header-right">
        <div class="pill">
          <div class="label">System Status</div>
          <div class="value online">● Online</div>
        </div>

        <div class="pill">
          <div class="label">Last Update</div>
          <div class="value" id="lastUpdate">--:--:--</div>
        </div>

        <div class="pill">
          <div class="label">AI Mode</div>
          <div class="value">Predictive</div>
        </div>
      </div>
    </div>

    <!-- LEFT -->
    <div class="left-col">
      <div class="hero-panel glass">
        <div class="risk-box">
          <div class="section-title">Current drought risk</div>

          <div class="big-risk">
            <div class="ring" id="mainRiskRing" style="--percent:72; --color: var(--orange);">
              <div class="ring-content">
                <h2 id="riskPercent">72%</h2>
                <span id="riskText">HIGH RISK</span>
              </div>
            </div>
          </div>

          <div class="risk-footer">
            <div class="mini-stat">
              <div class="small-label">Location</div>
              <div class="small-value">Wajir</div>
            </div>
            <div class="mini-stat">
              <div class="small-label">AI Confidence</div>
              <div class="small-value">91%</div>
            </div>
          </div>
        </div>

        <div class="status-panel">
          <div class="section-title">Current overview</div>

          <div class="status-badges">
            <div class="badge">
              <div class="name">Temperature</div>
              <div class="num" id="tempNum">34°C</div>
            </div>
            <div class="badge">
              <div class="name">Humidity</div>
              <div class="num" id="humNum">42%</div>
            </div>
            <div class="badge">
              <div class="name">Soil Moisture</div>
              <div class="num" id="soilNum">28%</div>
            </div>
            <div class="badge">
              <div class="name">Rainfall</div>
              <div class="num" id="rainNum">2 mm</div>
            </div>
          </div>

          <div class="recommendation">
            <strong>Recommended action:</strong><br>
            Begin irrigation planning, conserve water, apply mulching, and prepare drought-resistant crop support if risk remains above 70%.
          </div>

          <div class="alert">
            <strong>Alert:</strong> Soil moisture is dropping while temperature remains high. Rainfall has stayed low across the last monitoring cycle.
          </div>
        </div>
      </div>

      <div class="glass bars-panel">
        <div class="section-title">Live sensor intensity bars</div>

        <div class="bar-wrap">
          <div class="progress-item">
            <div class="progress-top">
              <span>Soil Moisture</span>
              <span id="soilBarLabel">28%</span>
            </div>
            <div class="bar"><div class="fill soil-fill" id="soilFill"></div></div>
          </div>

          <div class="progress-item">
            <div class="progress-top">
              <span>Temperature Load</span>
              <span id="tempBarLabel">76%</span>
            </div>
            <div class="bar"><div class="fill temp-fill" id="tempFill"></div></div>
          </div>

          <div class="progress-item">
            <div class="progress-top">
              <span>Humidity Level</span>
              <span id="humBarLabel">42%</span>
            </div>
            <div class="bar"><div class="fill hum-fill" id="humFill"></div></div>
          </div>

          <div class="progress-item">
            <div class="progress-top">
              <span>Rainfall Activity</span>
              <span id="rainBarLabel">10%</span>
            </div>
            <div class="bar"><div class="fill rain-fill" id="rainFill"></div></div>
          </div>
        </div>
      </div>
    </div>

    <!-- CENTER -->
    <div class="center-col">
      <div class="gauges-panel glass">
        <div class="section-title">Round percentage gauges</div>

        <div class="gauge-grid">
          <div class="gauge-card">
            <div class="gauge-title">Soil Moisture</div>
            <div class="small-ring" id="soilGauge" style="--percent:28; --color:#22c55e;">
              <span id="soilGaugeText">28%</span>
            </div>
            <div class="gauge-sub">Dry soil needs attention</div>
          </div>

          <div class="gauge-card">
            <div class="gauge-title">Humidity</div>
            <div class="small-ring" id="humidityGauge" style="--percent:42; --color:#38bdf8;">
              <span id="humidityGaugeText">42%</span>
            </div>
            <div class="gauge-sub">Moderate atmospheric moisture</div>
          </div>

          <div class="gauge-card">
            <div class="gauge-title">Rainfall</div>
            <div class="small-ring" id="rainGauge" style="--percent:10; --color:#8b5cf6;">
              <span id="rainGaugeText">10%</span>
            </div>
            <div class="gauge-sub">Very low precipitation</div>
          </div>

          <div class="gauge-card">
            <div class="gauge-title">Pressure Stability</div>
            <div class="small-ring" id="pressureGauge" style="--percent:68; --color:#f59e0b;">
              <span id="pressureGaugeText">68%</span>
            </div>
            <div class="gauge-sub">Weather pattern shifting</div>
          </div>
        </div>
      </div>

      <div class="glass bars-panel">
        <div class="section-title">Prediction summary</div>

        <div class="bar-wrap">
          <div class="progress-item">
            <div class="progress-top">
              <span>Low Risk Probability</span>
              <span>8%</span>
            </div>
            <div class="bar"><div class="fill" style="width:8%; background:linear-gradient(90deg,#4ade80,#16a34a);"></div></div>
          </div>

          <div class="progress-item">
            <div class="progress-top">
              <span>Moderate Risk Probability</span>
              <span>20%</span>
            </div>
            <div class="bar"><div class="fill" style="width:20%; background:linear-gradient(90deg,#fde047,#eab308);"></div></div>
          </div>

          <div class="progress-item">
            <div class="progress-top">
              <span>High Risk Probability</span>
              <span>72%</span>
            </div>
            <div class="bar"><div class="fill" style="width:72%; background:linear-gradient(90deg,#ffb347,#ff7b00);"></div></div>
          </div>

          <div class="progress-item">
            <div class="progress-top">
              <span>Severe Risk Trigger</span>
              <span>56%</span>
            </div>
            <div class="bar"><div class="fill" style="width:56%; background:linear-gradient(90deg,#fb7185,#ef4444);"></div></div>
          </div>
        </div>
      </div>
    </div>

    <!-- RIGHT -->
    <div class="right-col">
      <div class="chart-panel glass">
        <div class="section-title">Environmental trend chart</div>
        <div class="chart-box">
          <canvas id="trendChart"></canvas>
        </div>
      </div>

      <div class="trend-panel glass">
        <div class="section-title">Drought indicator mix</div>
        <div class="chart-box">
          <canvas id="mixChart"></canvas>
        </div>
        <div class="legend-note">Contribution of key variables to current drought prediction</div>
      </div>
    </div>
  </div>

  <script>
    // =========================
    // SAMPLE LIVE DATA
    // Replace these with ESP32 / Firebase / API values later
    // =========================
    const dashboardData = {
      temperature: 34,      // °C
      humidity: 42,         // %
      soilMoisture: 28,     // %
      rainfall: 2,          // mm
      rainfallPercent: 10,  // %
      pressure: 68,         // %
      droughtRisk: 72,      // %
      riskText: "HIGH RISK"
    };

    // =========================
    // CLOCK
    // =========================
    function updateTime() {
      const now = new Date();
      document.getElementById("lastUpdate").textContent = now.toLocaleTimeString();
    }
    updateTime();
    setInterval(updateTime, 1000);

    // =========================
    // HELPERS
    // =========================
    function setRing(id, percent, text, color){
      const el = document.getElementById(id);
      el.style.setProperty('--percent', percent);
      if(color) el.style.setProperty('--color', color);
      if(text !== undefined){
        const textEl = el.querySelector('span');
        if(textEl) textEl.textContent = text;
      }
    }

    function riskColor(percent){
      if(percent < 30) return "#22c55e";
      if(percent < 55) return "#facc15";
      if(percent < 75) return "#ff9d2e";
      return "#ff5757";
    }

    // =========================
    // APPLY DATA TO UI
    // =========================
    function loadDashboard(data){
      // top values
      document.getElementById("tempNum").textContent = `${data.temperature}°C`;
      document.getElementById("humNum").textContent = `${data.humidity}%`;
      document.getElementById("soilNum").textContent = `${data.soilMoisture}%`;
      document.getElementById("rainNum").textContent = `${data.rainfall} mm`;

      // risk ring
      document.getElementById("riskPercent").textContent = `${data.droughtRisk}%`;
      document.getElementById("riskText").textContent = data.riskText;
      document.getElementById("mainRiskRing").style.setProperty('--percent', data.droughtRisk);
      document.getElementById("mainRiskRing").style.setProperty('--color', riskColor(data.droughtRisk));

      // small gauges
      setRing("soilGauge", data.soilMoisture, `${data.soilMoisture}%`, "#22c55e");
      setRing("humidityGauge", data.humidity, `${data.humidity}%`, "#38bdf8");
      setRing("rainGauge", data.rainfallPercent, `${data.rainfallPercent}%`, "#8b5cf6");
      setRing("pressureGauge", data.pressure, `${data.pressure}%`, "#f59e0b");

      // labels
      document.getElementById("soilGaugeText").textContent = `${data.soilMoisture}%`;
      document.getElementById("humidityGaugeText").textContent = `${data.humidity}%`;
      document.getElementById("rainGaugeText").textContent = `${data.rainfallPercent}%`;
      document.getElementById("pressureGaugeText").textContent = `${data.pressure}%`;

      // progress bars
      document.getElementById("soilFill").style.width = `${data.soilMoisture}%`;
      document.getElementById("soilBarLabel").textContent = `${data.soilMoisture}%`;

      // temperature bar normalized against 45°C max
      const tempLoad = Math.min(100, Math.round((data.temperature / 45) * 100));
      document.getElementById("tempFill").style.width = `${tempLoad}%`;
      document.getElementById("tempBarLabel").textContent = `${tempLoad}%`;

      document.getElementById("humFill").style.width = `${data.humidity}%`;
      document.getElementById("humBarLabel").textContent = `${data.humidity}%`;

      document.getElementById("rainFill").style.width = `${data.rainfallPercent}%`;
      document.getElementById("rainBarLabel").textContent = `${data.rainfallPercent}%`;
    }

    loadDashboard(dashboardData);

    // =========================
    // CHART.JS GLOBAL STYLE
    // =========================
    Chart.defaults.color = "#dbe7f3";
    Chart.defaults.font.family = "Segoe UI, Arial, sans-serif";
    Chart.defaults.borderColor = "rgba(255,255,255,0.08)";

    // =========================
    // LINE CHART - ENVIRONMENTAL TREND
    // =========================
    const trendCtx = document.getElementById("trendChart").getContext("2d");
    new Chart(trendCtx, {
      type: 'line',
      data: {
        labels: ["6AM", "8AM", "10AM", "12PM", "2PM", "4PM", "6PM"],
        datasets: [
          {
            label: "Temperature °C",
            data: [27, 29, 31, 34, 35, 34, 32],
            borderColor: "#ffb347",
            backgroundColor: "rgba(255,179,71,0.18)",
            fill: true,
            tension: 0.4,
            borderWidth: 3,
            pointRadius: 3
          },
          {
            label: "Soil Moisture %",
            data: [46, 43, 40, 35, 31, 28, 26],
            borderColor: "#4ade80",
            backgroundColor: "rgba(74,222,128,0.12)",
            fill: true,
            tension: 0.4,
            borderWidth: 3,
            pointRadius: 3
          }
        ]
      },
      options: {
        maintainAspectRatio: false,
        responsive: true,
        plugins: {
          legend: {
            labels: {
              boxWidth: 12,
              usePointStyle: true
            }
          },
          tooltip: {
            backgroundColor: "rgba(10,15,20,0.95)",
            borderColor: "rgba(255,255,255,0.08)",
            borderWidth: 1
          }
        },
        scales: {
          x: {
            grid: { color: "rgba(255,255,255,0.06)" }
          },
          y: {
            grid: { color: "rgba(255,255,255,0.06)" },
            beginAtZero: true
          }
        }
      }
    });

    // =========================
    // DOUGHNUT CHART - INDICATOR MIX
    // =========================
    const mixCtx = document.getElementById("mixChart").getContext("2d");
    new Chart(mixCtx, {
      type: 'doughnut',
      data: {
        labels: ["Temperature", "Soil Moisture", "Humidity", "Rainfall", "Pressure"],
        datasets: [{
          data: [28, 30, 16, 18, 8],
          backgroundColor: [
            "#ff9d2e",
            "#22c55e",
            "#38bdf8",
            "#8b5cf6",
            "#f59e0b"
          ],
          borderWidth: 0,
          hoverOffset: 6
        }]
      },
      options: {
        maintainAspectRatio: false,
        cutout: "68%",
        plugins: {
          legend: {
            position: "bottom",
            labels: {
              color: "#dbe7f3",
              padding: 12,
              boxWidth: 12
            }
          },
          tooltip: {
            backgroundColor: "rgba(10,15,20,0.95)",
            borderColor: "rgba(255,255,255,0.08)",
            borderWidth: 1
          }
        }
      }
    });

    // =========================
    // OPTIONAL: DEMO LIVE CHANGES
    // remove this block if you don't want demo movement
    // =========================
    setInterval(() => {
      // small simulated movement
      dashboardData.temperature = Math.max(26, Math.min(40, dashboardData.temperature + (Math.random() > 0.5 ? 1 : -1)));
      dashboardData.humidity = Math.max(20, Math.min(70, dashboardData.humidity + (Math.random() > 0.5 ? 1 : -1)));
      dashboardData.soilMoisture = Math.max(10, Math.min(60, dashboardData.soilMoisture + (Math.random() > 0.5 ? 1 : -1)));

      // recalculate drought risk roughly
      dashboardData.droughtRisk = Math.max(
        20,
        Math.min(
          95,
          Math.round(
            (dashboardData.temperature * 1.6) +
            ((100 - dashboardData.soilMoisture) * 0.8) +
            ((100 - dashboardData.humidity) * 0.25)
          ) / 2
        )
      );

      dashboardData.riskText =
        dashboardData.droughtRisk < 30 ? "LOW RISK" :
        dashboardData.droughtRisk < 55 ? "MODERATE RISK" :
        dashboardData.droughtRisk < 75 ? "HIGH RISK" : "SEVERE RISK";

      loadDashboard(dashboardData);
    }, 5000);
  </script>
</body>
</html>
